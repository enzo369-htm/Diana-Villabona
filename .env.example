# Copiá a `.env.local` para desarrollo. En Vercel: Settings → Environment Variables.

# --- Panel /admin ---
# Contraseña que usa la clienta en /admin (validada en el servidor).
CMS_ADMIN_SECRET=una-frase-secreta-larga

# Solo desarrollo local con `npm run dev` (misma frase que arriba).
# VITE_ADMIN_PASSPHRASE=una-frase-secreta-larga

# VITE_ADMIN_DISABLED=true

# --- CMS en la nube (Supabase) — la clienta NO entra a Supabase ---
# Ejecutá supabase/schema.sql en SQL Editor.
#
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
